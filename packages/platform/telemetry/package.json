{
  "name": "@acme/telemetry",
  "dependencies": {
    "@kubiks/otel-drizzle": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "server-only": "catalog:"
  },
  "peerDependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./dist/index-server.d.ts",
      "default": "./src/index-server.ts"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./src/register.ts"
    }
  },
  "license": "MIT",
  "prettier": "@acme/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "acme": {
    "testClass": "backend-library",
    "testStatus": "todo",
    "reason": "OTel init seam; tests not yet written.",
    "infra": [
      "jaeger"
    ]
  }
}
