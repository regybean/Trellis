{
  "name": "@acme/db",
  "dependencies": {
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/test-utils": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@acme/vitest-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./src/testing.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "prettier": "@acme/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "acme": {
    "testClass": "backend-library",
    "testStatus": "todo",
    "reason": "Connection factory + env; behaviour is exercised through consumer suites (billing/chat/feedback/rag). A dedicated connection smoke test is a tracked follow-up.",
    "infra": [
      "postgres"
    ]
  }
}
