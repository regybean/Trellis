{
  "name": "@acme/chat",
  "dependencies": {
    "@acme/hooks": "workspace:*",
    "@acme/logger": "workspace:*",
    "@acme/rag": "workspace:*",
    "@acme/redis": "workspace:*",
    "@acme/subscriptions": "workspace:*",
    "@acme/telemetry": "workspace:*",
    "@acme/trpc": "workspace:*",
    "@acme/ui": "workspace:*",
    "@clerk/nextjs": "catalog:",
    "@mastra/core": "catalog:",
    "@mastra/rag": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "drizzle-orm": "catalog:",
    "lucide-react": "catalog:",
    "msw": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/redis": "workspace:*",
    "@acme/test-utils": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@acme/vitest-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "msw-trpc": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./dist/index-server.d.ts",
      "default": "./src/index-server.ts"
    },
    "./mastra": {
      "types": "./dist/mastra/index.d.ts",
      "default": "./src/mastra/index.ts"
    },
    "./schema": {
      "types": "./dist/index-schema.d.ts",
      "default": "./src/index-schema.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    }
  },
  "license": "MIT",
  "prettier": "@acme/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "pnpm test:backend && pnpm test:frontend",
    "test:backend": "vitest run --config vitest.config.backend.ts",
    "test:backend:watch": "vitest --watch --config vitest.config.backend.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:frontend:watch": "vitest --watch --config vitest.config.frontend.ts",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
