{
  "name": "@acme/hooks",
  "dependencies": {
    "@tanstack/query-persist-client-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "idb-keyval": "catalog:",
    "react": "catalog:",
    "react-toastify": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@acme/vitest-config": "workspace:*",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "fake-indexeddb": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "prettier": "@acme/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../../.prettierignore",
    "lint": "eslint",
    "test": "pnpm test:frontend",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:frontend:watch": "vitest --watch --config vitest.config.frontend.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "acme": {
    "testClass": "frontend-library"
  }
}
