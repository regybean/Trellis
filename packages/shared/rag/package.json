{
  "name": "@acme/rag",
  "private": true,
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./dist/index-schema.d.ts",
      "default": "./src/index-schema.ts"
    },
    "./server": {
      "types": "./dist/index-server.d.ts",
      "default": "./src/index-server.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "pnpm test:backend",
    "test:backend": "vitest run --config vitest.config.backend.ts",
    "test:backend:watch": "vitest --watch --config vitest.config.backend.ts",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@acme/prettier-config",
  "dependencies": {
    "@acme/logger": "workspace:*",
    "@acme/models": "workspace:*",
    "@mastra/core": "catalog:",
    "@mastra/memory": "catalog:",
    "@mastra/pg": "catalog:",
    "@mastra/rag": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "ai": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "officeparser": "catalog:",
    "postgres": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/test-utils": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@acme/vitest-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "acme": {
    "testClass": "backend-library",
    "infra": [
      "postgres",
      "ollama"
    ]
  }
}
