{
  "name": "@acme/llamaindex",
  "dependencies": {
    "@acme/logger": "workspace:*",
    "@aws-sdk/client-bedrock-runtime": "catalog:",
    "@aws-sdk/credential-providers": "^3.953.0",
    "@aws-sdk/types": "3.953.0",
    "@llamaindex/aws": "catalog:",
    "@llamaindex/env": "catalog:",
    "@llamaindex/postgres": "^0.0.65",
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "llama-cloud-services": "catalog:",
    "llamaindex": "catalog:",
    "p-limit": "catalog:",
    "pgvector": "catalog:",
    "pino": "^10.1.0",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./dist/index-schema.d.ts",
      "default": "./src/index-schema.ts"
    },
    "./server": {
      "types": "./dist/index-server.d.ts",
      "default": "./src/index-server.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    }
  },
  "license": "MIT",
  "prettier": "@acme/prettier-config",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
