/**
 * Test fixtures — factory helpers for creating consistent test data with
 * sensible, overridable defaults.
 */
import { redis } from '@acme/redis';

import type { SelectItemSchema } from '../../../api/schemas/item-schema';
import { items } from '../../../api/schemas/item-schema';
import { db } from '../../../api/trpc';

/** Clerk-style user id. */
export function createTestUserId(suffix?: string) {
  return `user_test_${suffix ?? crypto.randomUUID().slice(0, 8)}`;
}

export interface CreateTestItemOptions {
  userId?: string;
  text?: string;
}

/** Insert a single item row. */
export async function createTestItem(
  opts: CreateTestItemOptions = {},
): Promise<SelectItemSchema> {
  const [inserted] = await db
    .insert(items)
    .values({
      userId: opts.userId ?? createTestUserId(),
      text: opts.text ?? 'Test item',
    })
    .returning();

  if (!inserted) throw new Error('Failed to create test item');
  return inserted;
}

/** Insert `count` items for one user. */
export async function createTestItems(opts: {
  userId?: string;
  count?: number;
}): Promise<SelectItemSchema[]> {
  const userId = opts.userId ?? createTestUserId();
  const count = opts.count ?? 3;
  const created: SelectItemSchema[] = [];
  for (let i = 0; i < count; i++) {
    created.push(await createTestItem({ userId, text: `Test item ${i + 1}` }));
  }
  return created;
}

/** Seed Redis tokens so rate-limited procedures pass/fail deterministically. */
export async function setupTestTokens(
  userId: string,
  tier = 'Basic',
  remaining = 100,
) {
  if (!redis.isOpen) await redis.connect();
  await redis.set(`tokens:${userId}:${tier}`, remaining.toString());
}
