{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2023", "dom", "dom.iterable"],
    "jsx": "preserve",
    "paths": {
      "~/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }],
    "module": "esnext"
  },
  "include": [
    ".",
    ".next/types/**/*.ts",
    "../../packages/shared/auth/src/types/globals.d.ts"
  ],
  "exclude": ["node_modules"]
}
