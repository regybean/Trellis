# service-host env. Source of truth for env:pull / env:push.
#
# Rule:  KEY=value  -> non-secret, used as-is, never touches the secrets backend.
#        KEY=       -> secret, pulled from / pushed to the backend.
#        NEXT_PUBLIC_* are ALWAYS non-secret and are never pushed.

# Which feature router this process mounts (chat | ingest | feedback) and the
# port it listens on. Set per-process by the microservices showcase.
FEATURE=chat
PORT=4001

# Own per-app Postgres schema — isolated from every other app (ADR-0002). The
# selected feature's server graph reads this on boot.
NEXT_PUBLIC_WEBAPP=service_host
