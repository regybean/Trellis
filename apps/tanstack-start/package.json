{
  "name": "@acme/tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env vite build",
    "clean": "git clean -xdf .cache .nitro .output .tanstack .turbo node_modules",
    "dev": "pnpm with-env vite dev",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "start": "pnpm with-env node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env -- dotenv -e ./.env --"
  },
  "dependencies": {
    "@acme/admin": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/billing": "workspace:*",
