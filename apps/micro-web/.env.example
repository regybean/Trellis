# TanStack Start app env. Source of truth for env:pull / env:push.
#
# Rule:  KEY=value  -> non-secret, used as-is, never touches the secrets backend.
#        KEY=       -> secret, pulled from / pushed to the backend.
#        NEXT_PUBLIC_* are ALWAYS non-secret (they ship in the client bundle)
#                      and are never pushed, even when left empty here.

# Own per-app Postgres schema — isolated from every other app (ADR-0002).
NEXT_PUBLIC_WEBAPP=tanstack_slim
PORT=3003

# ── Clerk (auth) ──────────────────────────────────────────────────────────
# The @clerk/tanstack-react-start server SDK reads bare CLERK_PUBLISHABLE_KEY
# (no NEXT_PUBLIC_ support), so the publishable key is declared under both names.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# ── Stripe (billing) ──────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_MANAGE_BILLING_URL=
NEXT_PUBLIC_STRIPE_STANDARD_PLAN_ID=
NEXT_PUBLIC_STRIPE_PRO_PLAN_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3001/billing?success=true
STRIPE_CANCEL_URL=http://localhost:3001/billing?canceled=true
