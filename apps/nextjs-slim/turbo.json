{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tags": ["app"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "next-env.d.ts"]
    },
    "dev": {
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build", "build"]
    }
  }
}
