{
  "name": "@acme/test-utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./containers": {
      "types": "./dist/containers.d.ts",
      "default": "./src/containers.ts"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "default": "./src/setup.ts"
    },
    "./hydrate-env": {
      "types": "./dist/hydrate-env.d.ts",
      "default": "./src/hydrate-env.ts"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "default": "./src/vitest.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../../.gitignore",
    "lint": "eslint",
    "test": "pnpm test:backend",
    "test:backend": "vitest run --config vitest.config.backend.ts",
    "test:backend:watch": "vitest --watch --config vitest.config.backend.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@acme/vitest-config": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@testcontainers/postgresql": "^10.25.0",
    "@testcontainers/redis": "^10.25.0",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "testcontainers": "^10.25.0",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config",
  "acme": {
    "testClass": "backend-library"
  }
}
