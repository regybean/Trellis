{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "boundaries": {
    "tags": {
      "platform": {
        "dependencies": {
          "allow": ["platform", "tooling"]
        },
        "dependents": {
          "allow": ["platform", "shared", "feature", "app"]
        }
      },
      "shared": {
        "dependencies": {
          "allow": ["shared", "platform", "tooling"]
        },
        "dependents": {
          "allow": ["feature", "app", "shared"]
        }
      },
      "feature": {
        "dependencies": {
          "allow": ["shared", "platform", "tooling"]
        },
        "dependents": {
          "allow": ["app"]
        }
      },
      "app": {
        "dependencies": {
          "allow": ["feature", "shared", "platform", "tooling", "app"]
        }
      },
      "tooling": {
        "dependencies": {
          "allow": ["tooling"]
        },
        "dependents": {
          "allow": ["platform", "shared", "feature", "app", "tooling"]
        }
      }
    }
  },
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"],
      "outputLogs": "errors-only"
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/.eslintcache"],
      "outputLogs": "errors-only"
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"],
      "outputLogs": "errors-only"
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "test": {
      "env": ["CI"],
      "dependsOn": ["^topo", "^build"],
      "outputLogs": "errors-only"
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:frontend": {
      "env": ["CI"],
      "dependsOn": ["^topo", "^build"]
    },
    "test:frontend:watch": {
      "cache": false,
      "persistent": true
    },
    "test:backend": {
      "env": ["CI"],
      "dependsOn": ["^topo", "^build"]
    },
    "test:backend:watch": {
      "cache": false,
      "persistent": true
    },
    "boundaries": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    },
    "db:push": {
      "cache": false,
      "interactive": false
    },
    "db:generate": {
      "cache": false,
      "interactive": false
    }
  },
  "remoteCache": {
    "enabled": true,
    "signature": false
  },
  "globalEnv": [
    "DB_NAME",
    "DB_VECTOR_NAME",
    "DB_USER",
    "DB_PASSWORD",
    "DB_PORT",
    "DB_HOST",
    "NEXT_PUBLIC_WEBAPP",
    "IS_NEXT_BUILD",
    "PORT",
    "NEXT_PUBLIC_STRIPE_STANDARD_PLAN_ID",
    "NEXT_PUBLIC_STRIPE_PRO_PLAN_ID",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_STRIPE_MANAGE_BILLING_URL",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SIGNING_SECRET",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL",
    "REDIS_URL",
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "NODE_NO_WARNINGS",
    "WATCHPACK_POLLING",
    "REACT_EDITOR",
    "NPM_TOKEN",
    "STRIPE_API_BASE",
    "STRIPE_SECRET_KEY",
    "STRIPE_SUCCESS_URL",
    "STRIPE_CANCEL_URL",
    "STRIPE_WEBHOOK_SECRET"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event",
    "npm_package_version",
    "OTEL_SERVICE_NAME",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "DOCKER_HOST",
    "TESTCONTAINERS_RYUK_DISABLED",
    "TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE"
  ]
}
