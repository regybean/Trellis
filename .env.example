# Shared infrastructure. Source of truth for env:pull / env:push.
#
# Rule:  KEY=value  -> non-secret, used as-is, never touches the secrets backend.
#        KEY=       -> secret, pulled from / pushed to the backend.
# The values below are local-dev defaults (non-secret).

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=testdb
DB_VECTOR_NAME=vectordb
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- localstripe (dependency-free dev billing, default) ------------------
# Billing runs against the local `localstripe` infra service by default — no
# Stripe account or network needed. `pnpm infra:up` seeds the products/plans
# + webhook; grant tiers from the admin page (Set Tier). All dummy non-secret
# values. See docs/adr/0003-localstripe-dev-billing.md.
# To use real Stripe instead: unset STRIPE_API_BASE and pull the real keys
# (`pnpm env:pull`).
STRIPE_API_BASE=http://localhost:8420
STRIPE_SECRET_KEY=sk_test_localstripe
STRIPE_WEBHOOK_SECRET=whsec_localstripe
STRIPE_SUCCESS_URL=http://localhost:3000/billing
STRIPE_CANCEL_URL=http://localhost:3000/billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_localstripe
NEXT_PUBLIC_STRIPE_MANAGE_BILLING_URL=http://localhost:3000/billing
NEXT_PUBLIC_STRIPE_STANDARD_PLAN_ID=prod_dev_standard
NEXT_PUBLIC_STRIPE_PRO_PLAN_ID=prod_dev_pro
