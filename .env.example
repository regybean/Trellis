# Shared infrastructure. Source of truth for env:pull / env:push.
#
# Rule:  KEY=value  -> non-secret, used as-is, never touches the secrets backend.
#        KEY=       -> secret, pulled from / pushed to the backend.
# The values below are local-dev defaults (non-secret).

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=testdb
DB_VECTOR_NAME=vectordb
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
