# Shared infrastructure. Source of truth for env:pull / env:push.
#
# Rule:  KEY=value  -> non-secret, used as-is, never touches the secrets backend.
#        KEY=       -> secret, pulled from / pushed to the backend.
# The values below are local-dev defaults (non-secret).

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password123
DB_NAME=testdb
DB_VECTOR_NAME=vectordb
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- localstripe (dependency-free dev billing, default) ------------------
# Billing runs against the local `localstripe` infra service by default — no
# Stripe account or network needed. `pnpm infra:up` seeds the products/plans
# + webhook; grant tiers from the admin page (Set Tier). All dummy non-secret
# values. See docs/adr/0004-localstripe-dev-billing.md.
# To use real Stripe instead: unset STRIPE_API_BASE and pull the real keys
# (`pnpm env:pull`).
STRIPE_API_BASE=http://localhost:8420
STRIPE_SECRET_KEY=sk_test_localstripe
STRIPE_WEBHOOK_SECRET=whsec_localstripe
STRIPE_SUCCESS_URL=http://localhost:3000/billing
STRIPE_CANCEL_URL=http://localhost:3000/billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_localstripe
NEXT_PUBLIC_STRIPE_MANAGE_BILLING_URL=http://localhost:3000/billing
NEXT_PUBLIC_STRIPE_STANDARD_PLAN_ID=prod_dev_standard
NEXT_PUBLIC_STRIPE_PRO_PLAN_ID=prod_dev_pro

S3_ENDPOINT=http://localhost:4566
S3_UPLOAD_BUCKET=upload-temp-bucket

# Model providers. LLM (chat) and embeddings are selected independently.
# LLM_PROVIDER:   bedrock | openrouter | ollama
# EMBED_PROVIDER: bedrock | ollama        (OpenRouter has no embeddings API)
# Only the selected provider's vars are required; the rest can stay unset.
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama
# Vector dimension of the embed model. MUST match the model (nomic-embed-text=768,
# cohere.embed-english-v3=1024). Changing it requires re-pushing the schema.
EMBED_DIMENSIONS=768

# Ollama (local dev/test, CPU-only). Started by `infra:up` only when a provider
# above is `ollama`. Reached over its OpenAI-compatible /v1 endpoint.
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# AWS Bedrock (chat + Cohere embeddings). Credentials are secrets.
AWS_REGION=eu-west-2
BEDROCK_CHAT_MODEL=eu.anthropic.claude-3-7-sonnet-20250219-v1:0
BEDROCK_EMBED_MODEL=cohere.embed-english-v3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenRouter (chat only). API key is a secret.
OPENROUTER_CHAT_MODEL=
OPENROUTER_API_KEY=
